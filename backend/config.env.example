# Copy to config.env and fill in your values

# SMTP (outgoing – ticket confirmations, public links)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# IMAP (incoming – auto-create tickets from inbox)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Public ticket link base URL (for confirmation emails, welcome emails, support links)
# Used in first-time user welcome email: https://itsm.vardands.com/{product}?user_email={email}
PUBLIC_BASE_URL=http://localhost:3000

# Optional: IMAP poll interval in milliseconds (default: 60000 = 1 min)
# IMAP_POLL_INTERVAL_MS=60000
